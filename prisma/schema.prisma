
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RequestType {
  IMMEDIATE
  SCHEDULED
  GROUP
}

enum RequestStatus {
  DRAFT
  OPEN
  MATCHED
  COMPLETED
  CANCELED
  EXPIRED
}

enum CarpoolStatus {
  OPEN
  PENDING_CONFIRMATIONS
  CONFIRMED
  COMPLETED
  CANCELED
  EXPIRED
}

model User {
  id                     String     @id @default(uuid())
  email                  String     @unique
  userName               String     @unique
  passwordHash           String?
  campusId               String
  isDriverAvailable      Boolean    @default(false)
  emailVerified          Boolean    @default(false)
  emailVerifiedAt        DateTime?
  emailVerificationToken String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  lastLoginAt            DateTime?
  ridesCompleted         Int        @default(0)
  noShowCount            Int        @default(0)

  campus              Campus               @relation(fields: [campusId], references: [id])
  driverInfo          DriverInfo?
  sessions            Session[]
  notifications       Notification[]
  carpoolParticipants CarpoolParticipant[]
  carpoolMessages     CarpoolMessage[]
  stripeConnectedAccount StripeConnectedAccount?
  stripeProductsCreated  StripeProductMapping[]
}

model DriverInfo {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  legalName              String
  licenseNumber          String?
  issuingState           String?
  licenseExpirationDate  String?
  verified               Boolean  @default(false)
  verifiedAt             DateTime?
  lastVerifiedAt         DateTime?
  expirationAlertsSent   Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}


model Notification {
  id            String   @id @default(uuid())
  userId        String
  type          String
  message       String
  rideRequestId String?
  createdAt     DateTime @default(now())
  readAt        DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Campus {
  id          String   @id @default(uuid())
  name        String
  emailDomain String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model RideRequest {
  id            String        @id @default(uuid())
  riderId       String
  acceptedDriverId String?
  type          RequestType
  status        RequestStatus
  pickupLabel   String
  pickupAddress String
  dropoffLabel  String
  dropoffAddress String
  pickupNotes   String?
  partySize     Int
  pickupAt      DateTime
  carsNeeded    Int
  matchedAt     DateTime?
  canceledAt    DateTime?
  canceledBy    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([pickupAt])
}


model Carpool {
  id              String        @id @default(uuid())
  creatorId       String
  destination     String
  date            String
  timeStart       String
  timeEnd         String
  pickupArea      String
  seatsNeeded     Int
  targetGroupSize Int
  status          CarpoolStatus @default(OPEN)
  notes           String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lockedAt        DateTime?
  completedAt     DateTime?
  canceledAt      DateTime?
  expiredAt       DateTime?

  participants    CarpoolParticipant[]
  messages        CarpoolMessage[]

  @@index([status])
  @@index([date])
  @@index([destination])
  @@index([creatorId])
}

model CarpoolParticipant {
  id          String   @id @default(uuid())
  carpoolId   String
  userId      String
  joinedAt    DateTime @default(now())
  confirmedAt DateTime?
  isCreator   Boolean  @default(false)

  carpool     Carpool  @relation(fields: [carpoolId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([carpoolId, userId])
  @@index([userId])
  @@index([carpoolId])
}

model CarpoolMessage {
  id        String   @id @default(uuid())
  carpoolId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  carpool   Carpool  @relation(fields: [carpoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([carpoolId])
  @@index([createdAt])
}

model StripeConnectedAccount {
  id              String   @id @default(uuid())
  userId          String   @unique
  stripeAccountId String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  products StripeProductMapping[]
}

model StripeProductMapping {
  id                 String   @id @default(uuid())
  stripeProductId    String   @unique
  stripePriceId      String
  connectedAccountId String
  createdByUserId    String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connectedAccount StripeConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  createdByUser    User                   @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([connectedAccountId])
  @@index([createdByUserId])
}
